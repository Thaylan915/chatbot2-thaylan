# ==================== GEMINI API ====================
GEMINI_API_KEY=sua_chave_aqui

# ==================== BANCO DE DADOS ====================
POSTGRES_DB=chatbot
POSTGRES_USER=chatbot_user
POSTGRES_PASSWORD=chatbot2026

# Configuracao local (Django na maquina + PostgreSQL no Docker)
DB_HOST=127.0.0.1
DB_PORT=5555

# ==================== DJANGO ====================
SECRET_KEY=django-insecure-troque-por-uma-chave-muito-grande-e-secreta-aqui-123456789
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ==================== MODELOS DO GEMINI ====================
# Modelos estaveis recomendados
CHAT_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=embedding-001
TOP_K=5